# ============================================================
# caravan-lab — environment template
# Copy to .env and fill in all values. Never commit .env.
# ============================================================

# ------------------------------------------------------------
# Tailscale
# Generate at https://login.tailscale.com/admin/authkeys
# ------------------------------------------------------------
TAILSCALE_AUTHKEY=tskey-auth-REPLACE_ME

# ------------------------------------------------------------
# Cloudflare Tunnel
# Create tunnel at https://one.dash.cloudflare.com → Zero Trust → Tunnels
# Copy the token from the "Install and run connector" step
# ------------------------------------------------------------
TUNNEL_TOKEN=REPLACE_ME

# ------------------------------------------------------------
# PostgreSQL / TimescaleDB
# ------------------------------------------------------------
POSTGRES_USER=caravan
POSTGRES_PASSWORD=REPLACE_ME_STRONG_PASSWORD
POSTGRES_DB=caravan

# ------------------------------------------------------------
# Next.js / NextAuth
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate
# NEXTAUTH_URL: public URL served by Cloudflare Tunnel
# ------------------------------------------------------------
NEXTAUTH_SECRET=REPLACE_ME
NEXTAUTH_URL=https://caravan.c-knox.ch

# ------------------------------------------------------------
# MQTT (internal defaults — change only if you reconfigure Mosquitto)
# ------------------------------------------------------------
MQTT_HOST=mqtt
MQTT_PORT=1883

# ------------------------------------------------------------
# GPS device
# USB G-Mouse typically appears as /dev/ttyUSB0 on Pi OS.
# If it shows up as /dev/ttyACM0, change the value below.
# Check with: ls /dev/tty{USB,ACM}* after plugging in.
# ------------------------------------------------------------
GPS_DEVICE=/dev/ttyUSB0

# ------------------------------------------------------------
# ADS-B feeder location
# Used as static fallback before the first GPS fix and as the
# initial tar1090 map center. At runtime, readsb reads the live
# position from gpsd — the tar1090 blue dot follows the caravan.
# ALT_M: altitude of the home location above sea level in metres.
# SDR_SERIAL: RTL-SDR dongle serial number; "1090" works if only one dongle.
# ------------------------------------------------------------
FEEDER_LAT=47.3769
FEEDER_LON=8.5417
FEEDER_ALT_M=408
FEEDER_TZ=Europe/Zurich
ADSB_SDR_SERIAL=1090
